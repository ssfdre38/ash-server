{
  "$schema": "../../../schema/plugin.schema.json",
  "id": "echo-plugin",
  "name": "Echo Plugin",
  "version": "1.0.0",
  "description": "Example Python HTTP plugin. Echoes and reverses strings.",
  "enabled": false,
  "tools": [
    {
      "name": "echo",
      "description": "Echoes a message back to the user exactly as given.",
      "parameters": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "description": "The message to echo" }
        },
        "required": ["message"]
      },
      "handler": { "type": "http", "url": "http://localhost:19000/" }
    },
    {
      "name": "reverse",
      "description": "Reverses the characters in a string.",
      "parameters": {
        "type": "object",
        "properties": {
          "text": { "type": "string", "description": "The text to reverse" }
        },
        "required": ["text"]
      },
      "handler": { "type": "http", "url": "http://localhost:19000/" }
    }
  ]
}
